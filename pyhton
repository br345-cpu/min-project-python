from datetime import datetime

file_name = "payroll.txt"


# Decorator to log salary calculation
def log_salary(func):
    def wrapper(self):
        salary = func(self)
        log = f"{datetime.now()} - {self.name} salary calculated: {salary}\n"

        with open(file_name, "a") as f:
            f.write(log)

        return salary

    return wrapper


# Base class
class Employee:
    def __init__(self, name):
        self.name = name

    def calculate_salary(self):
        return 0


# Full-time employee
class FullTimeEmployee(Employee):
    def __init__(self, name, monthly_salary):
        super().__init__(name)
        self.monthly_salary = monthly_salary

    @log_salary
    def calculate_salary(self):
        return self.monthly_salary


# Part-time employee
class PartTimeEmployee(Employee):
    def __init__(self, name, hours, rate):
        super().__init__(name)
        self.hours = hours
        self.rate = rate

    @log_salary
    def calculate_salary(self):
        return self.hours * self.rate


# Save output to file
def export_employee(emp, salary):
    with open(file_name, "a") as f:
        f.write(f"{emp.name} final payout: {salary}\n")


# Main program
