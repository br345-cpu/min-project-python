import csv

input_file = "students.csv"
output_file = "students_result.csv"

# Function to calculate grade
def get_grade(marks):
    if marks >= 90:
        return "A"
    elif marks >= 75:
        return "B"
    elif marks >= 60:
        return "C"
    elif marks >= 40:
        return "D"
    else:
        return "F"

# Read input file and process data
def process_students():
    students = []

    try:
        with open(input_file, "r") as file:
            reader = csv.reader(file)

            for row in reader:
                name = row[0]
                marks = float(row[1])

                grade = get_grade(marks)

                students.append([name, marks, grade])

    except FileNotFoundError:
        print("Input file not found.")
        return []

    return students

# Write output file
def write_output(data):
    with open(output_file, "w", newline="") as file:
        writer = csv.writer(file)

        writer.writerow(["Name", "Marks", "Grade"])

        for row in data:
            writer.writerow(row)

    print("Result file created successfully.")

# Main program
data = process_students()

if data:
    write_output(data)

# Password Generator & Validator

import random
import string

# Custom Exception
class WeakPasswordError(Exception):
    pass

# Password Generator
def generate_password():
    all_chars = string.ascii_letters + string.digits + string.punctuation

    password = ""
    for i in range(10):
        password += random.choice(all_chars)

    return password

# Password Validator
def validate_password(password):
    if len(password) < 8:
        raise WeakPasswordError("Password too short")

    if not any(c.isupper() for c in password):
        raise WeakPasswordError("No uppercase letter")

    if not any(c.islower() for c in password):
        raise WeakPasswordError("No lowercase letter")

    if not any(c.isdigit() for c in password):
        raise WeakPasswordError("No digit")

    return True


# Main menu
while True:
    print("\n----- Password System -----")
    print("1. Generate Password")
    print("2. Validate Password")
    print("3. Exit")

    choice = input("Enter choice: ")

    if choice == "1":
        print("Generated Password:", generate_password())

    elif choice == "2":
        pwd = input("Enter password: ")

        try:
            validate_password(pwd)
            print("Password is strong.")
        except WeakPasswordError as e:
            print("Weak password:", e)

    elif choice == "3":
        print("Exit")
        break

    else:
        print("Invalid choice")

